# Shared
JOGAK_ENV=development
JOGAK_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32

# Secrets: keep these only on the server/worker side.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
REMOVE_BG_API_KEY=

# OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/auth/oauth/kakao/callback

# Backend
DATABASE_URL=postgresql+psycopg://jogak:jogak@localhost:5432/jogak
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_ISSUER=jogak-api
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
ASSET_BASE_URL=http://localhost:8000/assets
ASSET_STORAGE_ROOT=/SSD/guest/chojoonghui/JOGAK/data/assets
JOB_STORAGE_ROOT=/SSD/guest/chojoonghui/JOGAK/data/jobs
USER_UPLOAD_TTL_DAYS=30
PUBLIC_DATA_SYNC_ENABLED=false
TOURAPI_KEY=
CULTURE_DATA_KEY=
PATTERN_API_KEY=

# GPU / Hunyuan3D
CUDA_VISIBLE_DEVICES=7
NVIDIA_VISIBLE_DEVICES=7
CUDA_HOME=/usr/local/cuda-12.6
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
HUNYUAN3D_REPO=/SSD/guest/chojoonghui/JOGAK/third_party/Hunyuan3D-2.1
HUNYUAN3D_MODEL=tencent/Hunyuan3D-2.1
HUNYUAN3D_SUBFOLDER=hunyuan3d-dit-v2-1
HUNYUAN3D_ENABLE_TEXTURE=true
HUNYUAN3D_TEXTURE_RESOLUTION=1024
HUNYUAN3D_TARGET_FACE_COUNT=200000
HUNYUAN3D_NUM_INFERENCE_STEPS=50
HUNYUAN3D_GUIDANCE_SCALE=7.5
HUNYUAN3D_OCTREE_RESOLUTION=384
HUNYUAN3D_NUM_CHUNKS=200000
HUNYUAN3D_SEED=1234
HUNYUAN3D_TEXTURE_REMESH=false
HUNYUAN3D_BLENDER_POSTPROCESS=true
HUNYUAN3D_ROUND_PLINTH=true
HUNYUAN3D_PLINTH_HEIGHT_RATIO=0.075
JOGAK_ENABLE_HUNYUAN=true
JOGAK_SYNC_JOBS=false
BLENDER_BIN=/SSD/guest/chojoonghui/JOGAK/third_party/blender-4.5.10-linux-x64/blender
