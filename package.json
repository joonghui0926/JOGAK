{
  "name": "jogak",
  "private": true,
  "scripts": {
    "dev:frontend": "npm --prefix app/frontend run dev",
    "build:frontend": "npm --prefix app/frontend run build",
    "lint:frontend": "npm --prefix app/frontend run lint",
    "dev:backend": "conda run -n cjh_jogak uvicorn jogak_api.main:app --app-dir app/backend --reload --host 0.0.0.0 --port 8000",
    "seed": "conda run -n cjh_jogak python app/backend/scripts/seed_database.py",
    "verify:gpu": "bash scripts/verify_gpu7.sh"
  }
}
